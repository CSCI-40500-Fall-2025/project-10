# Server Configuration
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/find_housing

# Rate Limiting
API_RATE_LIMIT_WINDOW_MINUTES=60
BASIC_RATE_LIMIT_PER_HOUR=100
PREMIUM_RATE_LIMIT_PER_HOUR=1000

# Scraping
SCRAPE_CRON_SCHEDULE=0 */4 * * *
PUPPETEER_HEADLESS=true

# Logging
LOG_LEVEL=info

# Apify API Key (optional - for Zillow/Craigslist scraping)
# Get your API key from: https://console.apify.com/account/integrations
APIFY_KEY=your_apify_api_key_here
